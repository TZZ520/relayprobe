# Real API calls are opt-in. The test suite and mock runs do not require keys.
RELAYPROBE_API_KEY=replace-with-your-relay-key
RELAYPROBE_BASE_URL=https://example-relay.invalid
RELAYPROBE_MODEL=gpt-4o

# Optional official baseline target for differential runs.
RELAYPROBE_CONTROL_API_KEY=replace-with-official-provider-key
RELAYPROBE_CONTROL_BASE_URL=https://api.openai.com
RELAYPROBE_CONTROL_MODEL=gpt-4o

